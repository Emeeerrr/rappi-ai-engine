# OpenRouter API Key (required)
# Get yours at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_key_here

# Default LLM model (optional, defaults to Claude Sonnet 4)
# Options: anthropic/claude-sonnet-4.6, openai/gpt-4o, google/gemini-2.5-flash, meta-llama/llama-4-maverick
DEFAULT_MODEL=anthropic/claude-sonnet-4.6
